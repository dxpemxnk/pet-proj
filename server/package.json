  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js --ext js,jsx,json",
    "dev2": "node --watch app.js",
    "dbc": "npx sequelize db:create",
    "dbd": "npx sequelize db:drop",
    "dbmig": "npx sequelize db:migrate:undo:all && npx sequelize db:migrate",
    "dbseed": "npx sequelize db:seed:undo:all && npx sequelize db:seed:all",
    "up": "npx sequelize db:create && npx sequelize db:migrate && npx sequelize db:seed:all",
